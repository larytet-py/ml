# Prioritized set

# IBIT call: Very broad and stable quality, with 91.5% positive rate among usable rows and 5,839 robust cells.
--symbol IBIT --signal-model roc --side call --roc-window-size 23 --vol-window-size 7 --roc-comparator below --roc-threshold -0.077453 --vol-comparator above --vol-threshold 0.325709

# TLT call: Broad and stable quality, with 76.5% positive rate among usable rows and 813 robust cells.
--symbol TLT --signal-model roc --side call --roc-window-size 8 --vol-window-size 27 --roc-comparator below --roc-threshold -0.021312 --vol-comparator above --vol-threshold 0.016817

# VXX put: Broad quality with one dominant region, with 71.7% positive rate among usable rows and 6,982 robust cells.
--symbol VXX --signal-model roc --side put --roc-window-size 50 --vol-window-size 15 --roc-comparator below --roc-threshold 0.028323 --vol-comparator above --vol-threshold 0.450429

# IBIT put: Mixed quality but one dominant area, with 46.4% positive rate among usable rows and 2,277 robust cells.
--symbol IBIT --signal-model roc --side put --roc-window-size 34 --vol-window-size 10 --roc-comparator below --roc-threshold -0.203980 --vol-comparator above --vol-threshold 0.130603

# IWM put: Very broad and stable quality, with 88.4% positive rate among usable rows and 2,073 robust cells.
--symbol IWM --signal-model roc --side put --roc-window-size 60 --vol-window-size 22 --roc-comparator below --roc-threshold 0.157740 --vol-comparator above --vol-threshold 0.134024

# SPY put: Broad quality but drawdowns can be large, with 82.9% positive rate among usable rows and 1,191 robust cells.
--symbol SPY --signal-model roc --side put --roc-window-size 49 --vol-window-size 24 --roc-comparator below --roc-threshold 0.023452 --vol-comparator above --vol-threshold 0.093480

# TLT put: Smaller but coherent quality, with 36.2% positive rate among usable rows and 183 robust cells.
--symbol TLT --signal-model roc --side put --roc-window-size 46 --vol-window-size 5 --roc-comparator below --roc-threshold -0.038882 --vol-comparator above --vol-threshold 0.042164

# GDX put: Promising but rougher quality, with 34.1% positive rate among usable rows and 1,544 robust cells.
--symbol GDX --signal-model roc --side put --roc-window-size 19 --vol-window-size 18 --roc-comparator below --roc-threshold 0.037118 --vol-comparator above --vol-threshold 0.460170

# Deprioritized set

# GDX call: Very sparse quality, with 4.3% positive rate among usable rows and 24 robust cells.
--symbol GDX --signal-model roc --side call --roc-window-size 7 --vol-window-size 27 --roc-comparator below --roc-threshold -0.043516 --vol-comparator above --vol-threshold 0.253052

# IWM call: Sparse and selective quality, with 11.1% positive rate among usable rows and 56 robust cells.
--symbol IWM --signal-model roc --side call --roc-window-size 6 --vol-window-size 2 --roc-comparator below --roc-threshold 0.085586 --vol-comparator above --vol-threshold 0.105586

# SPY call: Too thin to trust much, with 5.0% positive rate among usable rows and 1 robust cell.
--symbol SPY --signal-model roc --side call --roc-window-size 7 --vol-window-size 3 --roc-comparator below --roc-threshold 0.025305 --vol-comparator above --vol-threshold 0.065588
